{
  "engines": {
    "node": "24.12.0"
  },
  "name": "doomsday-wiki",
  "private": true,
  "version": "3.0.0",
  "scripts": {
    "build": "concurrently 'pnpm:build:*' --kill-others --names --prefix-colors auto --success first",
    "build:next": "next build",
    "build:scryfall": "pnpm run scryfall",
    "dev": "concurrently 'pnpm:dev:*' --names --prefix-colors auto",
    "dev:next": "next dev",
    "dev:scryfall": "DEBUG=1 pnpm run scryfall",
    "lint": "pnpm run --aggregate-output '/^lint:[^:]+$/'",
    "lint:code": "eslint",
    "lint:content": "markdownlint --config markdownlint.config.js markdown/",
    "lint:format": "prettier --check --log-level warn app/ components/ contexts/ hooks/ markdown/ puzzles/ scryfall/ theme/ tools/",
    "lint:prune": "knip",
    "lint:typings": "tsc",
    "scryfall": "tsx ./scryfall/server.ts",
    "start": "next start",
    "test": "jest",
    "test:coverage": "pnpm run test --coverage",
    "test:watch": "pnpm run test --verbose --watchAll"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@fontsource/libre-baskerville": "5.2.10",
    "@korumite/kiwi": "3.4.2",
    "@mdi/js": "7.4.47",
    "@mdi/react": "1.6.1",
    "@mui/material": "7.3.6",
    "@mui/material-nextjs": "7.3.6",
    "async-sema": "3.1.1",
    "mana-font": "1.18.0",
    "mdast-util-find-and-replace": "3.0.2",
    "next": "15.5.9",
    "plaiceholder": "3.0.0",
    "posthog-js": "1.310.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "10.1.0",
    "react-syntax-highlighter": "16.1.0",
    "rehype-slug": "6.0.0",
    "remark-directive": "4.0.0",
    "remark-gfm": "4.0.1",
    "sharp": "0.34.5",
    "simple-icons": "16.2.0",
    "unist-util-select": "5.1.0",
    "unist-util-visit": "5.0.0",
    "zod": "4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@ianvs/prettier-plugin-sort-imports": "4.7.0",
    "@korumite/ts": "1.1.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.1",
    "@types/jest": "29.5.14",
    "@types/mdast": "4.0.4",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@types/react-syntax-highlighter": "15.5.13",
    "concurrently": "9.2.1",
    "eslint": "9.39.2",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-react-hooks": "5.2.0",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "knip": "5.76.3",
    "markdownlint-cli": "0.47.0",
    "mdast-util-directive": "3.1.0",
    "prettier": "3.7.4",
    "ts-node": "10.9.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.50.1",
    "unified": "11.0.5"
  }
}
