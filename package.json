{
  "engines": {
    "node": "24.16.0"
  },
  "name": "doomsday-wiki",
  "private": true,
  "type": "module",
  "version": "3.0.0",
  "scripts": {
    "build": "concurrently 'pnpm:build:*' --kill-others --names --success first",
    "build:next": "next build",
    "build:scrydrop": "pnpm run scrydrop",
    "dev": "concurrently 'pnpm:dev:*' --names",
    "dev:next": "next dev",
    "dev:scrydrop": "pnpm run scrydrop --debug",
    "lint": "pnpm run --aggregate-output '/^lint:[^:]+$/'",
    "lint:code": "oxlint",
    "lint:content": "markdownlint --config markdownlint.config.cjs markdown/",
    "lint:format": "prettier --check --log-level warn app/ components/ contexts/ hooks/ markdown/ puzzles/ theme/ tools/",
    "lint:prune": "knip",
    "lint:typings": "tsc",
    "scrydrop": "scrydrop --port 3333 --rate 1",
    "start": "next start",
    "test": "vitest run --reporter=dot",
    "test:coverage": "pnpm run test --coverage",
    "test:watch": "pnpm run test --watch"
  },
  "dependencies": {
    "@emotion/cache": "11.14.0",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@korumite/kiwi": "5.8.0",
    "@korumite/scrydrop": "1.5.1",
    "@mdi/js": "7.4.47",
    "@mdi/react": "1.6.1",
    "@mui/material": "9.0.1",
    "@mui/material-nextjs": "9.0.1",
    "mana-font": "1.18.0",
    "mdast-util-find-and-replace": "3.0.2",
    "mdast-util-to-string": "4.0.0",
    "next": "16.2.7",
    "posthog-js": "1.378.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-markdown": "10.1.0",
    "react-syntax-highlighter": "16.1.1",
    "rehype-slug": "6.0.0",
    "remark-directive": "4.0.0",
    "remark-gfm": "4.0.1",
    "sharp": "0.34.5",
    "simple-icons": "16.22.0",
    "unist-util-visit": "5.1.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@korumite/ts": "1.6.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@types/react-syntax-highlighter": "15.5.13",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/coverage-v8": "4.1.8",
    "concurrently": "10.0.1",
    "happy-dom": "20.9.0",
    "knip": "6.15.0",
    "markdownlint-cli": "0.48.0",
    "oxlint": "1.68.0",
    "oxlint-tsgolint": "0.23.0",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
