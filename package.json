{
  "engines": {
    "node": "24.15.0"
  },
  "name": "doomsday-wiki",
  "private": true,
  "version": "3.0.0",
  "scripts": {
    "build": "concurrently 'pnpm:build:*' --kill-others --names --prefix-colors auto --success first",
    "build:next": "next build",
    "build:scrydrop": "pnpm run scrydrop",
    "dev": "concurrently 'pnpm:dev:*' --names --prefix-colors auto",
    "dev:next": "next dev",
    "dev:scrydrop": "pnpm run scrydrop --debug",
    "lint": "pnpm run --aggregate-output '/^lint:[^:]+$/'",
    "lint:code": "eslint",
    "lint:content": "markdownlint --config markdownlint.config.js markdown/",
    "lint:format": "prettier --check --log-level warn app/ components/ contexts/ hooks/ markdown/ puzzles/ theme/ tools/",
    "lint:prune": "knip",
    "lint:typings": "tsc",
    "scrydrop": "scrydrop --port 3333 --rate 1",
    "start": "next start",
    "test": "vitest run",
    "test:coverage": "pnpm run test --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@emotion/cache": "11.14.0",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@korumite/kiwi": "5.3.0",
    "@korumite/scrydrop": "1.3.0",
    "@mdi/js": "7.4.47",
    "@mdi/react": "1.6.1",
    "@mui/material": "7.3.10",
    "@mui/material-nextjs": "7.3.10",
    "mana-font": "1.18.0",
    "mdast-util-find-and-replace": "3.0.2",
    "mdast-util-to-string": "4.0.0",
    "next": "15.5.15",
    "posthog-js": "1.372.9",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-markdown": "10.1.0",
    "react-syntax-highlighter": "16.1.1",
    "rehype-slug": "6.0.0",
    "remark-directive": "4.0.0",
    "remark-gfm": "4.0.1",
    "sharp": "0.34.5",
    "simple-icons": "16.18.1",
    "unist-util-select": "5.1.0",
    "unist-util-visit": "5.1.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@korumite/ts": "1.5.0",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/mdast": "4.0.4",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-syntax-highlighter": "15.5.13",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.5",
    "concurrently": "9.2.1",
    "eslint": "9.39.4",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-react-hooks": "5.2.0",
    "happy-dom": "20.9.0",
    "knip": "6.12.0",
    "markdownlint-cli": "0.48.0",
    "mdast-util-directive": "3.1.0",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.58.0",
    "unified": "11.0.5",
    "vitest": "4.1.5"
  }
}
