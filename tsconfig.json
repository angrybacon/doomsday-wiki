{
  "compilerOptions": {
    "allowJs": true,
    "jsx": "preserve",
    "paths": {
      "@/app/*": ["./app/*"],
      "@/contexts/*": ["./contexts/*"],
      "@/components/*": ["./components/*"],
      "@/hooks/*": ["./hooks/*"],
      "@/theme/*": ["./theme/*"],
      "@/tools/*": ["./tools/*"]
    },
    "plugins": [{ "name": "next" }],
    "target": "ES2017",
    "types": ["@testing-library/jest-dom", "vitest/globals"]
  },
  "exclude": ["node_modules"],
  "extends": "./node_modules/@korumite/ts/tsconfig.dom.json",
  "include": [
    "**/*.mts",
    "**/*.ts",
    "**/*.tsx",
    ".next/dev/types/**/*.ts",
    ".next/types/**/*.ts",
    "next-env.d.ts"
  ]
}
